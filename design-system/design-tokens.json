{
  "$schema": "https://design.linkup.studio/schemas/design-tokens.json",
  "name": "LinkUp Studio Design Tokens",
  "version": "1.0.0",
  "description": "Complete design token system for LinkUp Studio",
  
  "imports": [
    "./colors.json",
    "./typography.json",
    "./spacing.json",
    "./radius.json",
    "./animations.json"
  ],
  
  "colors": {
    "bg-canvas": "#0d1117",
    "bg-surface": "#161b22",
    "bg-elevated": "#21262d",
    "bg-overlay": "#30363d",
    "bg-inset": "#010409",
    
    "border-default": "#30363d",
    "border-muted": "#21262d",
    "border-accent": "rgba(56, 139, 253, 0.4)",
    "border-active": "#58a6ff",
    
    "text-primary": "#e6edf3",
    "text-secondary": "#8b949e",
    "text-tertiary": "#6e7681",
    "text-disabled": "#484f58",
    "text-inverse": "#0d1117",
    "text-link": "#58a6ff",
    "text-placeholder": "#6e7681",
    
    "accent-fg": "#58a6ff",
    "accent-emphasis": "#1f6feb",
    "accent-muted": "rgba(56, 139, 253, 0.15)",
    
    "success-fg": "#3fb950",
    "success-emphasis": "#238636",
    "success-muted": "rgba(63, 185, 80, 0.15)",
    
    "warning-fg": "#d29922",
    "warning-emphasis": "#9e6a03",
    "warning-muted": "rgba(210, 153, 34, 0.15)",
    
    "danger-fg": "#f85149",
    "danger-emphasis": "#da3633",
    "danger-muted": "rgba(248, 81, 73, 0.15)",
    
    "purple-accent": "#a371f7",
    "orange-accent": "#f0883e",
    "blue-accent": "#58a6ff",
    "pink-accent": "#db61a2"
  },
  
  "typography": {
    "font-sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
    "font-mono": "'JetBrains Mono', 'Fira Code', Consolas, monospace",
    
    "text-xs": "0.6875rem",
    "text-sm": "0.75rem",
    "text-base": "0.875rem",
    "text-md": "0.9375rem",
    "text-lg": "1rem",
    "text-xl": "1.25rem",
    "text-2xl": "1.5rem",
    "text-3xl": "1.875rem",
    
    "font-weight-normal": 400,
    "font-weight-medium": 500,
    "font-weight-semibold": 600,
    "font-weight-bold": 700,
    
    "line-height-tight": 1.25,
    "line-height-normal": 1.5,
    "line-height-relaxed": 1.625,
    "line-height-mono": 1.4
  },
  
  "spacing": {
    "space-0": "0",
    "space-px": "1px",
    "space-0-5": "2px",
    "space-1": "4px",
    "space-1-5": "6px",
    "space-2": "8px",
    "space-2-5": "10px",
    "space-3": "12px",
    "space-3-5": "14px",
    "space-4": "16px",
    "space-5": "20px",
    "space-6": "24px",
    "space-7": "28px",
    "space-8": "32px",
    "space-9": "36px",
    "space-10": "40px",
    "space-12": "48px",
    "space-14": "56px",
    "space-16": "64px",
    "space-20": "80px",
    "space-24": "96px"
  },
  
  "radius": {
    "radius-none": "0px",
    "radius-sm": "4px",
    "radius-md": "6px",
    "radius-lg": "8px",
    "radius-xl": "12px",
    "radius-2xl": "16px",
    "radius-full": "9999px"
  },
  
  "shadow": {
    "shadow-xs": "0 1px 0 rgba(27, 31, 36, 0.04)",
    "shadow-sm": "0 1px 2px rgba(0, 0, 0, 0.3)",
    "shadow-md": "0 4px 12px rgba(0, 0, 0, 0.4)",
    "shadow-lg": "0 8px 24px rgba(0, 0, 0, 0.5)",
    "shadow-xl": "0 16px 48px rgba(0, 0, 0, 0.6)",
    "shadow-glow": "0 0 0 3px rgba(56, 139, 253, 0.3)",
    "shadow-glow-success": "0 0 0 3px rgba(63, 185, 80, 0.3)",
    "shadow-glow-danger": "0 0 0 3px rgba(248, 81, 73, 0.3)"
  },
  
  "motion": {
    "duration-instant": "50ms",
    "duration-fast": "150ms",
    "duration-normal": "250ms",
    "duration-slow": "400ms",
    "duration-slower": "600ms",
    
    "ease-out": "cubic-bezier(0.16, 1, 0.3, 1)",
    "ease-in-out": "cubic-bezier(0.65, 0, 0.35, 1)",
    "ease-spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "ease-bounce": "cubic-bezier(0.68, -0.55, 0.265, 1.55)"
  },
  
  "layout": {
    "titlebar-height": "32px",
    "sidebar-width": "56px",
    "sidebar-width-expanded": "240px",
    "activity-panel-width": "320px",
    "statusbar-height": "24px",
    "tab-height": "36px"
  },
  
  "zIndex": {
    "z-base": 0,
    "z-dropdown": 100,
    "z-sticky": 200,
    "z-overlay": 300,
    "z-modal": 400,
    "z-popover": 500,
    "z-tooltip": 600,
    "z-toast": 700
  },
  
  "components": {
    "button": {
      "height-sm": "28px",
      "height-md": "32px",
      "height-lg": "40px",
      "padding-sm": "4px 8px",
      "padding-md": "8px 12px",
      "padding-lg": "12px 16px",
      "radius": "6px",
      "font-size": "0.75rem",
      "font-weight": 500
    },
    
    "input": {
      "height": "36px",
      "padding": "0 12px",
      "radius": "6px",
      "font-size": "0.875rem"
    },
    
    "card": {
      "padding": "16px",
      "radius": "8px",
      "border": "1px solid #21262d"
    },
    
    "modal": {
      "padding": "24px",
      "radius": "12px",
      "max-width": "480px"
    },
    
    "dropdown": {
      "padding": "4px",
      "radius": "8px",
      "shadow": "0 8px 24px rgba(0, 0, 0, 0.5)"
    },
    
    "tooltip": {
      "padding": "6px 8px",
      "radius": "6px",
      "font-size": "0.75rem"
    }
  }
}
