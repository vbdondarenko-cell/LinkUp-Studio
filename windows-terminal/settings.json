      "cyan": "#39c5cf",
      "brightCyan": "#56d4dd",
      "white": "#b1bac4",
      "brightWhite": "#e6edf3"
    }
  ],
  "startOnUserLogin": false,
  "startupMenu": {
    "behavior": "openOnFirstTab",
    "mostRecentlyUsedCommandCount": 5
  },
  "themes": [
    {
      "name": "GitHub Dark",
      "tab": {
        "background": "#161b22",
        "activeBackground": "#0d1117",
        "showCloseButton": "always",
        "unselectedCloseButton": "visible",
        "hoverBackground": "#21262d"
      },
      "taskbar": {
        "backgroundImage": null,
        "overlayColor": "#58a6ff",
        "overlayOpacity": 0.8
      },
      "titlebar": {
        "background": "#161b22",
        "前景色": "#e6edf3",
        "borderColor": "#30363d",
        "button": {
          "background": "#21262d",
          "hoverBackground": "#30363d",
          "activeBackground": "#1f6feb",
          "foreground": "#e6edf3",
          "hoverForeground": "#e6edf3",
          "activeForeground": "#ffffff"
        }
      },
      "body": {
        "background": "#0d1117",
        "foreground": "#e6edf3",
        "cursorColor": "#58a6ff",
        "selectionBackground": "#388bfd40"
      },
      "window": {
        "border": "#30363d",
        "borderRadius": 8,
        "shadow": true
      }
    }
  ],
  "profiles": {
    "defaults": {
      "font": {
        "face": "JetBrains Mono",
        "size": 12,
        "weight": "normal",
        "cellWidth": 1.0,
        "cellHeight": 1.0
      },
      "cursor": {
        "style": "bar",
        "height": 25,
        "color": "#58a6ff"
      },
      "scrollbarState": {
        "visibility": "visible",
        "thumbColor": "#30363d",
        "trackColor": "#21262d"
      },
      "colorScheme": "GitHub Dark",
      "acrylicOpacity": 0.8,
      "useAcrylic": true,
      "backgroundImage": null,
      "backgroundImageOpacity": 1.0,
      "backgroundImageStretch": "uniformToFill",
      "opacity": 95,
      "padding": "8, 8, 8, 8",
      "snapOnInput": true,
      "historySize": 10000,
      "altClickDisclaimer": true,
      "bellStyle": "none",
      "bellSound": null,
      "disableAnimations": false,
      "cursorShape": "bar",
      "cursorBlink": true,
      "trimBlockSelection": true,
      "trimPaste": true,
      "wordDelimiters": " /\\()\"'-.,:;<>~!@#$%^&*|+=[]{}~?\u2502\u2503\u2523\u252b\u2533\u253b\u254b\u2560\u2563\u256b\u2571\u2572\u2573",
      "suppressApplicationTitle": false,
      "environmentVariables": {
        "TERM": "xterm-256color"
      }
    },
    "list": [
      {
        "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
        "name": "PowerShell",
        "commandline": "pwsh -NoLogo",
        "icon": "ms-appx:///Assets/PowerShell.png",
        "tabTitle": "PowerShell",
        "startingDirectory": "%USERPROFILE%",
        "hidden": false,
        "tabColor": "#1f6feb",
        "profileLocalization": {
          "name": "PowerShell"
        }
      },
      {
        "guid": "{0caa0dad-0350-4e93-9a81-37e892a1e2a2}",
        "name": "Command Prompt",
        "commandline": "cmd.exe",
        "icon": "ms-appx:///Assets/cmd.png",
        "tabTitle": "Command Prompt",
        "startingDirectory": "%USERPROFILE%",
        "hidden": false,
        "tabColor": "#3fb950"
      },
      {
        "guid": "{b453ae62-4e3d-5e58-b989-0a998ecf0437}",
        "name": "Azure Cloud Shell",
        "commandline": "CloudShell",
        "source": "Windows.Terminal.Azure",
        "hidden": false,
        "tabColor": "#58a6ff"
      },
      {
        "guid": "{2c4de342-38b7-51cf-b940-2309a097f518}",
        "name": "Ubuntu",
        "commandline": "wsl -d Ubuntu",
        "icon": "ms-appx:///ProfileIcons/{2c4de342-38b7-51cf-b940-2309a097f518}.png",
        "tabTitle": "Ubuntu",
        "startingDirectory": "%USERPROFILE%",
        "hidden": false,
        "tabColor": "#e95420",
        "colorScheme": "GitHub Dark"
      },
      {
        "name": "Developer Dashboard",
        "guid": "{linkup-developer-dashboard}",
        "commandline": "pwsh -NoLogo -NoExit -c \"oh-my-posh init pwsh --config '~$env:POSH_THEMES_PATH\\bubbles.omp.json' | Invoke-Expression; echo 'LinkUp Studio Developer Terminal'; echo ''; git branch --show-current 2>$null; Get-ChildItem -Force -ErrorAction SilentlyContinue | Select-Object Mode, LastWriteTime, Length, Name | Format-Table -AutoSize\"",
        "icon": "ms-appx:///Assets/LinkUpStudio.png",
        "tabTitle": "Developer",
        "startingDirectory": "%USERPROFILE%",
        "hidden": false,
        "tabColor": "#a371f7",
        "colorScheme": "GitHub Dark",
        "acrylicOpacity": 0.85,
        "cursorShape": "bar",
        "cursorBlink": true,
        "font": {
          "face": "JetBrains Mono",
          "size": 12,
          "weight": "medium"
        },
        "environmentVariables": {
          "TERM": "xterm-256color",
          "POWERSHELL_TELEMETRY_OPTOUT": "1"
        }
      },
      {
        "name": "Git Status",
        "guid": "{linkup-git-status}",
        "commandline": "pwsh -NoLogo -NoExit -c \"$GitPromptSettings = @{ BeforeText = '['; AfterText = ']'; ForegroundColor = '#8b949e'; BranchColor = '#58a6ff'; BranchAheadStatusColor = '#3fb950'; BranchBehindStatusColor = '#f85149'; BranchGoneStatusColor = '#d29922'; BeforePathText = ' '; AfterPathText = ''; DelimText = ':'; ErrorColor = '#f85149'; WorkingColor = '#d29922'; StagedColor = '#a371f7' }; oh-my-posh init pwsh --config '~$env:POSH_THEMES_PATH\\bubbles.omp.json' | Invoke-Expression\"",
        "icon": "ms-appx:///Assets/Git.png",
        "tabTitle": "Git",
        "startingDirectory": "%USERPROFILE%",
        "hidden": false,
        "tabColor": "#f85149",
        "colorScheme": "GitHub Dark",
        "font": {
          "face": "JetBrains Mono",
          "size": 11,
          "weight": "normal"
        }
      },
      {
        "name": "Quick Terminal",
        "guid": "{linkup-quick-terminal}",
        "commandline": "pwsh -NoLogo -NoExit",
        "icon": "ms-appx:///Assets/Quick.png",
        "tabTitle": "Terminal",
        "startingDirectory": "%USERPROFILE%",
        "hidden": false,
        "tabColor": "#3fb950",
        "colorScheme": "GitHub Dark Dim",
        "acrylicOpacity": 0.6,
        "opacity": 80,
        "font": {
          "face": "JetBrains Mono",
          "size": 10
        }
      }
    ]
  },
  "keybindings": [],
  "windowBehavior": {
    "launchMode": "default",
    "alwaysOnTop": false,
    "newInstanceMode": "useExisting"
  },
  "rendering": {
    "dxEngine": {
      "enabled": true,
      "experimentalRedraw": true,
      "forceFullRepaint": true
    },
    "softwareRendering": false,
    "directWrite": true,
    "directX": {
      "enabled": true,
      "highContrast": false,
      "edgeChromium": true
    }
  },
  "ui": {
    "showTabsInTitlebar": true,
    "showTerminalTitleInTitlebar": true,
    "terminalTitleSize": 12,
    "tabWidthMode": "compact",
    "tabRowHeight": 32,
    "showAllTabsIfMultiple": true,
    "alwaysShowTabs": false,
    "maxTabWidth": 200,
    "minTabWidth": 100,
    "tabMaxWidth": 200,
    "tabMinWidth": 180,
    "tabPaddingWidth": 8,
    "showIconOnTabs": true,
    "showColorOnTabs": true,
    "experimentalShowTeardsOnTabsList": false,
    "dragAndDrop": true,
    "copyOnSelect": false,
    "trimOnCopy": true,
    "openOnFullClick": false,
    "middleClickToClose": true,
    "showTabsInTaskbar": true,
    "alwaysShowNotificationIcon": false,
    "notificationSilencerInterval": 3600,
    "visualBellSpeed": 500,
    "screenLineHeight": "uniform",
    "screenPadding": "0, 0, 0, 0",
    "inverseSelection": false,
    "selectionBox": false,
    "selectionBoxColor": "#388bfd40",
    "rectangularSelection": true,
    "gridLayout": {
      "snapToGrid": true
    }
  },
  "input": {
    "copyPaste": {
      "copyOnSelect": false,
      "trimOnCopy": true,
      "copyAs ANSI": true,
      "convertPaste": {
        "fromRtf": true,
        "fromHTML": true
      }
    },
    "history": {
      "historySize": 100,
      "autosave": true,
      "sync": true,
      "loadFromCloud": false
    },
    "completion": {
      "autosuggestion": true,
      "prediction": {
        "enabled": true,
        "source": "history"
      },
      "appearance": {
        "color": "#8b949e",
        "highlightColor": "#58a6ff40"
      }
    }
  },
  "performance": {
    "disableStartup噪声": false,
    "enableStartupNoise": false,
    "enablePaintHost": true,
    "enableScrollbars": true,
    "disablePartialInvalidation": false
  },
  "globals": {
    "alwaysOnTop": false,
    "initialCols": 120,
    "initialRows": 30,
    "launchMode": "default",
    "minimizeToNotificationArea": false,
    "notifyOnExit": "closeOnlyOnExit",
    "showReleaseNotes": true,
    "startOnUserLogin": false,
    "windowingBehavior": "useExisting"
  }
}